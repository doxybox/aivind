# Database
DATABASE_URL=
DATABASE_URI=
DATABASE_POOL_MAX=1

# Public content source
CONTENT_SOURCE=legacy

# Better Auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3005

# Optional Better Auth social/email adapters. Leave empty unless enabled.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
RESEND_API_KEY=
EMAIL_FROM=

# Supabase is used as Postgres/database only. Do not use Supabase Auth.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Payload CMS
PAYLOAD_SECRET=
PAYLOAD_DATABASE_URL=
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000

# Payload local QA/seeding helpers
ALLOW_PAYLOAD_DEMO_SEED=false
PAYLOAD_DEMO_SEED_OPERATION_TIMEOUT_MS=15000
PAYLOAD_DEMO_SEED_VERBOSE=false
PAYLOAD_VERIFY_STRICT=false
PAYLOAD_VERIFY_TIMEOUT_MS=15000

# Deprecated / only if Ghost is explicitly reintroduced later.
# GHOST_URL=
# GHOST_CONTENT_API_URL=
# GHOST_CONTENT_API_KEY=
# GHOST_WEBHOOK_SECRET=

# Deprecated Base44 compatibility. Leave disabled unless intentionally testing legacy proxy fallback.
NEXT_PUBLIC_BASE44_APP_ID=
NEXT_PUBLIC_BASE44_FUNCTIONS_VERSION=
NEXT_PUBLIC_BASE44_APP_BASE_URL=
ALLOW_BASE44_API_REWRITE=false

# Cloudflare Images/Stream. Runtime is parked unless CLOUDFLARE_MEDIA_ENABLED=true.
CLOUDFLARE_MEDIA_ENABLED=false
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_IMAGES_API_TOKEN=
CLOUDFLARE_IMAGES_ACCOUNT_HASH=
CLOUDFLARE_IMAGES_DEFAULT_VARIANT=public

# Cloudflare Stream
CLOUDFLARE_STREAM_API_TOKEN=
CLOUDFLARE_STREAM_WEBHOOK_SECRET=
CLOUDFLARE_STREAM_CUSTOMER_CODE=

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Local/dev-only tooling
ALLOW_TEST_ENTITLEMENT_GRANT=false
ALLOW_TEST_BILLING_CHECKOUT=false

# Billing. Leave empty/disabled while payment runtime is parked.
BILLING_PROVIDER=
BILLING_PUBLIC_ORIGIN=http://localhost:3000

# Vipps MobilePay Recurring - fill when customer has credentials.
VIPPS_ENV=test
VIPPS_BASE_URL=https://apitest.vipps.no
VIPPS_CLIENT_ID=
VIPPS_CLIENT_SECRET=
VIPPS_SUBSCRIPTION_KEY=
VIPPS_MERCHANT_SERIAL_NUMBER=
VIPPS_WEBHOOK_SECRET=
VIPPS_RETURN_URL=http://localhost:3000/abonnement/status
VIPPS_CANCEL_URL=http://localhost:3000/abonnement
VIPPS_WEBHOOK_URL=https://your-public-dev-url.example/api/billing/webhooks/vipps
