{
  "name": "Invoice",
  "type": "object",
  "properties": {
    "amount": {
      "type": "number"
    },
    "due_date": {
      "type": "string",
      "format": "date"
    },
    "status": {
      "type": "string",
      "enum": [
        "paid",
        "pending",
        "overdue"
      ]
    },
    "pdf_url": {
      "type": "string"
    }
  },
  "required": [
    "amount",
    "due_date",
    "status"
  ]
}